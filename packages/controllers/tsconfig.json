{
  "compilerOptions": {
    "strict": true,
    "declaration": true,
    "declarationMap": false,
    "moduleResolution": "bundler",
    "lib": ["ES2019", "ES2020.Intl", "DOM"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "module": "ES6",
    "target": "ES2019",
    "removeComments": true,
    "sourceMap": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": [
    "./src/**/*.js",
    "./src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
